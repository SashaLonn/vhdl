library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity ssi_master is 
port (
    clk                       :in  std_logic;
    reset_n                   :in  std_logic;  --  used for simulation
    rxd                       :in  std_logic ;
    txd                       :out std_logic;
    ssi_clk                   :out std_logic;
    ssi_data                  :in  std_logic;
    ssi_data_dir              :out std_logic;
    ssi_clk_dir               :out std_logic;
    ssi2_charge_signal        :out std_logic; -- extra signal for SSI 2 
    ssi2_charge_signal_dir    :out std_logic; -- extra signal for SSI 2 
    led_1                     :out std_logic;
    led_2                     :out std_logic
);
end ssi_master;

architecture rtl of ssi_master is

   
  --ssi2 signals 
  signal ssi2_clk_i                  :std_logic;
  signal ssi2_clk_i_old              :std_logic;
  signal charge_signal_i             :std_logic;
  signal ssi2_charge_pulse_counter_l :integer range 0 to 20;
  signal ssi2_charge_pulse_counter_h :integer range 0 to 5;
  signal ssi2_clk_hp_counter         :integer range 0 to SSI_CLK_HP_COUNT_MAX;
  
  signal ssi2_clk_hp_counter_extra   :integer range 0 to SSI_CLK_HP_COUNT_MAX;
  signal ssi2_clk_hp_count           :integer range 0 to SSI_CLK_HP_COUNT_MAX;
  signal ssi2_bit_counter            :integer range 0 to 2**POS_NR_BIT_WIDTH - 1;
  signal ssi2_bit_count              :integer range 0 to 2**POS_NR_BIT_WIDTH - 1;
  signal ssi2_position               :std_logic_vector(16 - 1 downto 0);
  --signal ssi2_position               :std_logic_vector(POS_BYTE_WIDTH * 8 - 1 downto 0);

  signal ssi2_position_g_to_b        :std_logic_vector(16 - 1 downto 0);
  signal charge_pulse_en             :std_logic;
  signal new_position_ssi2           :std_logic;
  
  
  --signal position_ssi2                :std_logic_vector(POS_BYTE_WIDTH * 8 - 1 downto 0);
  signal position_ssi2                :std_logic_vector(16 - 1 downto 0);
  signal position_ssi2_read           :std_logic_vector(POS_BYTE_WIDTH * 8 - 1 downto 0);
  signal position_ssi2_parity_r      :std_logic_vector(POS_BYTE_WIDTH * 8 - 1 downto 0);
  signal nr_pos_bytes_ssi2            :integer range 0 to POS_BYTE_WIDTH;
  signal ssi2_first_reading           :std_logic;
  signal ssi2_pos_ready               :std_logic;
  signal parity                       :std_logic := '0';
  signal parity_check                 :std_logic := '0';
  signal parity_check_r               :std_logic := '0';
  signal eval_parity                  :std_logic := '0';
  signal parity_error                 :std_logic := '0';
  signal start_receiving              :std_logic;
  signal low_ready                    :std_logic;
  
  type ssi2_state_type                 is (IDLE,RECEIVING,STORE_DATA);
  signal ssi2_state                    :ssi2_state_type;
begin
  ssi_clk_dir             <= '1';
  ssi_data_dir            <= '0'; 
  ssi2_charge_signal_dir  <= '1';
  
  
  ssi2_proc:process (reset_n, clk)
begin
  if reset_n = '0' then   
    ssi2_clk_hp_counter    <=  0;
    ssi2_clk_i_old         <= '0';
    ssi2_clk_i             <= '0';
  elsif clk'event and clk  = '1' then
    if parameters_set = '1' then
      if ssi2_clk_hp_counter = ssi2_clk_hp_count then
        ssi2_clk_hp_counter  <= 0;
        ssi2_clk_i           <= not ssi2_clk_i; 
      else 
        ssi2_clk_hp_counter  <= ssi2_clk_hp_counter + 1;
        ssi2_clk_i_old       <= ssi2_clk_i;      
      end if;
    end if;   
  end if;
end process;

ssi2_charge_signal_proc:process (reset_n,clk)
begin
  if reset_n = '0' then
    charge_signal_i              <= '1';
    start_receiving              <= '0';
    low_ready                    <= '0';
    ssi2_charge_pulse_counter_h  <= 0;
    ssi2_charge_pulse_counter_l  <= 0;
  elsif clk' event and clk = '1' then 
    start_receiving <= '0';   
    if ssi2_clk_i_old = '1'and ssi2_clk_i = '0' and charge_pulse_en = '1' then    
      if ssi2_charge_pulse_counter_l < 19 then
        charge_signal_i     <= '0';
        ssi2_charge_pulse_counter_l   <= ssi2_charge_pulse_counter_l + 1;
      else
        low_ready          <= '1';
      end if;
      
      if low_ready = '1' then  
        if ssi2_charge_pulse_counter_h < 4 then 
          charge_signal_i    <= '1';
          ssi2_charge_pulse_counter_h <= ssi2_charge_pulse_counter_h + 1;      
        else
          ssi2_charge_pulse_counter_h <=  0;
          ssi2_charge_pulse_counter_l <=  0;
          start_receiving             <= '1';  
          low_ready                   <= '0';  
        end if;
      end if;      
    end if;
  end if;
end process;

ss2_clock_in_data:process (reset_n,clk)
begin
  if reset_n = '0' then
    ssi2_bit_counter        <=  0;
    ssi2_position           <= (others => '0');
    ssi2_position_g_to_b    <= (others => '0');
    position_ssi2           <= (others => '0');
    position_ssi2_read      <= (others => '0');
    new_position_ssi2       <= '0';
    nr_pos_bytes_ssi2       <=  0;
    ssi2_pos_ready          <= '0';
    ssi2_state              <= IDLE;
    eval_parity             <= '0';  
    parity                  <= '0';  
    parity_check            <= '0';  
    parity_check_r          <= '0';  
    parity_error            <= '0';  
  elsif clk' event and clk   = '1' then
    new_position_ssi2 <= '0';    
    if eval_parity  = '1' then  
      parity       <= parity xor ssi_data_s;
      parity_check <= not parity;
      eval_parity  <= '0';
    end if;
    
    case ssi2_state is 
      when IDLE => 
        if start_receiving = '1' then
          ssi2_state      <= RECEIVING;
          parity          <= '0';
          parity_check    <= '0';  
        else
          ssi2_state <= IDLE;
        end if;
      when RECEIVING =>
        if  ssi2_clk_i_old = '1'and ssi2_clk_i = '0' then
          if ssi2_bit_counter < ssi2_bit_count  then
            ssi2_position(15)              <= ssi_data_s;
            ssi2_position(16 - 2 downto 0) <= ssi2_position(16- 1 downto 1);
            ssi2_bit_counter               <= ssi2_bit_counter + 1;
            eval_parity                    <= '1';
          end if;
            
          if ssi2_bit_counter = ssi2_bit_count  then
            ssi2_bit_counter  <= 0;
            position_ssi2     <= ssi2_position;
            nr_pos_bytes_ssi2 <= 2;
            ssi2_pos_ready    <='1';
            ssi2_state        <= STORE_DATA;
          end if;
        end if; 
      when STORE_DATA =>
        if ssi2_pos_ready = '1' then
          if position_ssi2 (15) /= parity_check then
            parity_error                    <= '1';
            position_ssi2_read(13 downto 0) <= (others => '1');
            ssi2_state                      <= IDLE;
          else        
            position_ssi2_read(13 downto 0)     <= position_ssi2(14 downto 1);
            new_position_ssi2                   <= '1';
            parity_check_r                      <= parity_check;  
            ssi2_pos_ready                      <= '0';
            position_ssi2_parity_r(15 downto 0) <=  position_ssi2(15 downto 0); 
            ssi2_state                          <= IDLE;
          end if;             
        end if;
      when others =>
        ssi2_state <= IDLE;  
    end case;  
  end if;
end process;

ssi_com_proc:process(reset_n,clk)
begin
  if reset_n = '0' then
    error_r_pos           <= '0';
    start_ssi             <= '0';
    continuous_error      <= '0';
    nr_con_reads_counter  <= 0;
    ssi_clk_i             <= '1';
    ssi_busy              <= '0';
    run_tcal_counter      <= '0';
    run_ssi_clk_counter   <= '0';
    tcal_counter          <= 0;
    ssi_clk_hp_counter    <= 0;
    ssi_bit_counter       <= 0;
    position_i            <= (others => '0');
    position_g_to_b       <= (others => '0');
    position_i_mt         <= (others => '0');
    position_g_to_b_mt    <= (others => '0');
    ssi_data_s            <= '0';
    ssi_data_s2           <= '0';
    wait_data_done        <= '0';
    wdd_to_us_counter     <= 0;
    pt_counter            <= 0;
    pt_tick               <= '0';
    run_pt_counter        <= '0';
    new_position          <= '0';
    pos_ready             <= '0';
    position              <= (others => '0');
    position_old          <= (others => '0');
    st_position           <= (others => '0');
    mt_position           <= (others => '0');
    st_max_bit            <= 0;
    mt_max_bit            <= 0;
    pos_equal             <= '0';
    compare_positions     <= '0';
    mt_enable             <= '0';
    mt_counter            <= (others => '0');

  elsif clk'event and clk = '1' then
    error_r_pos           <= '0';
    start_ssi             <= '0';
    pt_tick               <= '0';
    pos_ready             <= '0';
    new_position          <= '0';
    compare_positions     <= '0';
    ssi_data_s            <= ssi_data;
    ssi_data_s2           <= ssi_data_s;
    
    if bit_nr_error = '0' then
      mt_min_bit            <= conv_integer(nr_st_bits);
      if nr_st_bits > 0 then
        st_max_bit            <= conv_integer(nr_st_bits) - 1;
      else
        st_max_bit            <= 0;
      end if;
      if nr_mt_bits > 0 then
        mt_pos_max_bit        <= conv_integer(nr_mt_bits) - 1;
        mt_enable             <= '1';
      else
        mt_pos_max_bit        <= 0;
        mt_enable             <= '0';
      end if;
      if nr_pos_bits > 0 then
        mt_max_bit            <= conv_integer(nr_pos_bits) - 1;
      else
        mt_max_bit            <= 0;
      end if;
    end if;    
    
    if start_ssi = '1' then
      ssi_clk_i           <= '0';
      ssi_busy            <= '1';
      position_i          <= (others => '0');
      position_g_to_b     <= (others => '0');
      position_i_mt       <= (others => '0');
      position_g_to_b_mt  <= (others => '0');
      mt_counter          <= (others => '0');
      
      if control_reg(C_BIT_USE_TCAL) = '1' and tcal_count /= 0 then
        run_tcal_counter    <= '1';
      else
        run_ssi_clk_counter <= '1';      
      end if;
    end if;
    
    if run_tcal_counter = '1' then
      if tcal_counter >= tcal_count then
        tcal_counter        <= 0;
        run_tcal_counter    <= '0';
        run_ssi_clk_counter <= '1';
      else
        tcal_counter        <= tcal_counter + 1;
      end if;
    end if;
    
    if pos_ready = '1' then
      if control_reg(C_BIT_NR_CONS_POS_FIRST_POS) = '1' then
        if nr_con_reads_counter = 1 then -- only first read if multiple reads
          new_position <= '1';

      else
        if nr_con_reads_counter = nr_con_reads_count then -- only first read if multiple reads
          new_position <= '1';
        end if;
      end if;
      st_position  <= (others => '0');
      mt_position  <= (others => '0');
      if control_reg(C_BIT_GRAY_TO_BIN) = '1' then -- encoder has gray code outout
        position <= position_g_to_b;
        st_position(st_max_bit downto 0)      <= position_g_to_b(st_max_bit downto 0);
        mt_position                           <= position_g_to_b_mt;
      end if;
      else
        position <= position_i;
        st_position(st_max_bit downto 0)      <= position_i(st_max_bit downto 0);
        mt_position                           <= position_i_mt;
      end if;
      position_old <= position;
      compare_positions <= '1';
    end if;
    
    if compare_positions = '1' then
      if control_reg(C_BIT_COMPARE_POSITIONS) = '1' then
        if position = position_old then
          pos_equal <= '1';
        else
          pos_equal <= '0';
        end if;
      else
        pos_equal <= '0';
      end if;
    end if;
        
    if run_ssi_clk_counter = '1' then
      if ssi_clk_hp_counter >= ssi_clk_hp_count then
        ssi_clk_hp_counter  <= 0;
        ssi_clk_i           <= not ssi_clk_i;
        if ssi_clk_i = '0' then
          if ssi_bit_counter > 0 then
            position_i(0) <= ssi_data_s;
            position_i(POS_BYTE_WIDTH * 8 - 1 downto 1) <= position_i(POS_BYTE_WIDTH * 8 - 2 downto 0);
            -- gray  to bin
            if ssi_bit_counter = 1 then
              position_g_to_b(0) <= ssi_data_s;
            else
              position_g_to_b(0) <= position_g_to_b(0) xor ssi_data_s;
            end if;
            position_g_to_b(POS_BYTE_WIDTH * 8 - 1 downto 1) <= position_g_to_b(POS_BYTE_WIDTH * 8 - 2 downto 0);
            if mt_enable = '1' then
              if mt_counter < nr_mt_bits then
                position_i_mt(0) <= ssi_data_s;
                position_i_mt(POS_BYTE_WIDTH * 8 - 1 downto 1) <= position_i_mt(POS_BYTE_WIDTH * 8 - 2 downto 0);
                if ssi_bit_counter = 1 then
                  position_g_to_b_mt(0) <= ssi_data_s;
                else
                  position_g_to_b_mt(0) <= position_g_to_b_mt(0) xor ssi_data_s;
                end if;
                position_g_to_b_mt(POS_BYTE_WIDTH * 8 - 1 downto 1) <= position_g_to_b_mt(POS_BYTE_WIDTH * 8 - 2 downto 0);
                mt_counter <= mt_counter + 1;
              end if;
            end if;
          end if;
          if ssi_bit_counter >= ssi_bit_count then
            ssi_bit_counter     <= 0;
            run_ssi_clk_counter <= '0';
            run_pt_counter      <= '1';
            wait_data_done      <= '1';
            pos_ready           <= '1';
          else
            ssi_bit_counter <= ssi_bit_counter + 1;
          end if;
        end if;
      else
        ssi_clk_hp_counter <= ssi_clk_hp_counter + 1;
      end if;
    end if;
    
    if run_pt_counter = '1' then
      if pt_counter >= pt_count then
        run_pt_counter  <= '0';
        pt_counter      <= 0;
        pt_tick         <= '1';
      else
        pt_counter      <= pt_counter + 1;
      end if;
    end if;
    
    if wait_data_done = '1' then
      if ssi_data_s2 = '0' and ssi_data_s = '1' then
        wdd_to_us_counter <= 0;
        ssi_busy          <= '0';
        wait_data_done    <= '0';
      end if;
      if tick_1us = '1' then
        if wdd_to_us_counter = WDD_TO_US_COUNT then
          wdd_to_us_counter <= 0;
          ssi_busy          <= '0';
          wait_data_done    <= '0';
        else
          wdd_to_us_counter <= wdd_to_us_counter + 1;
        end if;
      end if;
    end if;
    
    -- trigger a start
    if parameters_set = '1' then
      if control_reg(C_BIT_CONTINUOUS_POS) = '1' then
        if control_reg(C_BIT_USE_SAMPLE_INTERVAL) = '1' then
          if si_tick = '1' and ssi_busy = '0' and bit_nr_error = '0' then
            start_ssi             <= '1';
            continuous_error      <= '0';
            nr_con_reads_counter  <= 1; -- this is the first read
          end if;
        elsif control_reg(C_BIT_USE_PAUS_TIME) = '1' then
          if pt_tick = '1' then -- don't care about the busy signal
            start_ssi             <= '1';
            continuous_error      <= '0';
            nr_con_reads_counter  <= 1; -- this is the first read
          end if;
        else -- no selection of the above is selected
          continuous_error <= '1';
        end if;
      else
        if trig_read_pos = '1' and ssi_busy = '0' then
          if bit_nr_error = '1' then
            error_r_pos           <= '1';
          else
            start_ssi             <= '1';
            nr_con_reads_counter  <= 1; -- this is the first read
          end if;
        end if;
      end if;
      
      -- trigger consecutive reads
      if nr_con_reads_counter < nr_con_reads_count then -- nr reads are done
        if pt_tick = '1' then -- don't care about the busy signal
          start_ssi             <= '1';
          nr_con_reads_counter  <= nr_con_reads_counter + 1;
        end if;
      end if;
    end if;    
  end if;
end process;
 


end architecture;


--set_instance_assignment -name POWER_UP_LEVEL LOW -to reset_n
--set_instance_assignment -name POWER_UP_LEVEL LOW -to reset_n1
--set_instance_assignment -name POWER_UP_LEVEL LOW -to reset_n2
--set_location_assignment PIN_E1 -to clk
--set_location_assignment PIN_B1 -to rxd
--set_location_assignment PIN_N2 -to ssi_clk
--set_location_assignment PIN_P2 -to ssi_data
--set_location_assignment PIN_C2 -to txd
--set_location_assignment PIN_P3 -to ssi_data_dir
--set_location_assignment PIN_N1 -to ssi_clk_dir
--set_location_assignment PIN_T13 -to ssi_output_1
--set_location_assignment PIN_T12 -to ssi_output_2